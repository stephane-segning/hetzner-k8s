hcloud_token = "YOUR_HCLOUD_TOKEN"

cluster_name = "hetzner-k8s"

control_plane_server_type = "cpx22"
worker_server_type        = "cpx42"

control_plane_count = 3
worker_count        = 2

location = "nbg1"

ssh_key_ids = ["your-ssh-key-name"]

api_load_balancer_type = "lb11"

# Strongly recommended when using the dedicated API load balancer.
# Point DNS to the API load balancer IP and use the hostname here.
api_server_hostname = "k8s.example.com"

create_data_volumes = false
data_volume_size_gb = 50

k3s_version = "v1.35.3+k3s1"
k3s_token   = ""

oidc_issuer_url      = "https://keycloak.example.com/realms/platform"
oidc_client_id       = "kubernetes"
oidc_username_claim  = "preferred_username"
oidc_groups_claim    = "groups"
oidc_username_prefix = "-"
oidc_groups_prefix   = ""

extra_server_args = ""
extra_agent_args  = ""
