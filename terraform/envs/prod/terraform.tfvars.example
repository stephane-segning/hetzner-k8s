hcloud_token = "YOUR_HCLOUD_TOKEN"

cluster_name = "hetzner-k8s"

control_plane_server_type = "cpx22"
worker_server_type        = "cpx42"

control_plane_count = 3
worker_count        = 2

location = "fsn1"

ssh_key_ids = ["your-ssh-key-name"]

allowed_ssh_ips = ["YOUR_IP/32"]

# Keep this empty when using the dedicated API load balancer.
# Set it only if you intentionally want direct API access to node public IPs.
allowed_api_ips = []

api_load_balancer_type = "lb11"

create_data_volumes = false
data_volume_size_gb = 50

k3s_version = "latest"
k3s_token   = ""

extra_server_args = ""
extra_agent_args  = ""
